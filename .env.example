# ─────────────────────────────────────────────────────────────────────────────
# LLM Prompt Optimizer — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Policy ────────────────────────────────────────────────────────────────────
LPO_STRICT_INTENT=true
LPO_SEMANTIC_THRESHOLD=0.90
LPO_TOKEN_BUDGET=8000

# ── MCP Server ────────────────────────────────────────────────────────────────
LPO_MCP_HOST=127.0.0.1
LPO_MCP_PORT=8765
LPO_MCP_TRANSPORT=stdio          # stdio | http | websocket | ipc

# ── Logging ───────────────────────────────────────────────────────────────────
LPO_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Graph Provider (optional) ─────────────────────────────────────────────────
# Leave empty to use built-in FallbackGraphEngine (no external tools needed)
LPO_GRAPH_PROVIDER=              # graphify | code_review_graph

# ── LLM Adapters (optional) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OLLAMA_BASE_URL=http://localhost:11434

# ── Telemetry (optional) ──────────────────────────────────────────────────────
# LPO_TELEMETRY_BACKEND=opentelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
